// schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  // Relations
  expenses     Expense[]
  balances     Balance[]
  incomes      Income[]
  transactions Transaction[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  date        String
  month       String
  category    String
  description String
  createdAt   DateTime @default(now())

  // Relation
  user   User @relation(fields: [userId], references: [id])
  userId Int
}

model Income {
  id          Int      @id @default(autoincrement())
  amount      Float
  date        String
  month       String
  description String
  createdAt   DateTime @default(now())

  // Relation
  user   User @relation(fields: [userId], references: [id])
  userId Int
}

model Balance {
  id     Int    @id @default(autoincrement())
  userId Int
  month  String
  amount Int
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, month]) // 👈 composite unique constraint (user + month only)
}

model Transaction {
  id          Int     @id @default(autoincrement())
  type        String // "income" or "expense"
  amount      Float
  description String?
  date        String
  user        User    @relation(fields: [userId], references: [id])
  userId      Int
}
